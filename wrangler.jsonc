{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "commission-index",
  "compatibility_date": "2026-02-05",
  "vars": {},
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "preview_urls": false,
  "workers_dev": false,
  "routes": [
    {
      "pattern": "crystallize.cc",
      "custom_domain": true
    }
  ]
}
