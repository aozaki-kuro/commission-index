---
type AdminSection = 'admin' | 'aliases' | 'suggestion'

interface Props {
  current: AdminSection
}

const { current } = Astro.props as Props

const sectionLinks: Array<{ key: AdminSection; label: string; href: string }> = [
  { key: 'admin', label: 'Admin', href: '/admin' },
  { key: 'aliases', label: 'Aliases', href: '/admin/aliases' },
  { key: 'suggestion', label: 'Suggestion', href: '/admin/suggestion' },
]
---

<nav aria-label="Admin sections" class="flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-4">
    {
      sectionLinks.map(item =>
        item.key === current ? (
          <span aria-current="page" class="cursor-default text-gray-500 dark:text-gray-400">
            {item.label}
          </span>
        ) : (
          <a href={item.href}>{item.label}</a>
        ),
      )
    }
  </div>

  <div class="flex items-center gap-4">
    <a href="/">Home</a>
  </div>
</nav>
