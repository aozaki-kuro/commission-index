---
import type { Commission } from '#data/types'
import { parseAndFormatDate } from '#lib/date/format'
import { parseCommissionFileName } from '#lib/commissions/index'
import {
  COMMISSION_LINK_TEXT_CLASS,
  hasDisplayableLinks,
  selectDisplayLinks,
} from '#features/home/commission/linkDisplay'
import { getHomeLocaleMessages, normalizeHomeLocale } from '#features/home/i18n/homeLocale'

interface IllustratorInfoProps {
  locale?: string
  commission: Commission
  kebabName: string
  showLinks?: boolean
}

const { locale, commission, kebabName, showLinks = true } = Astro.props as IllustratorInfoProps
const messages = getHomeLocaleMessages(normalizeHomeLocale(locale))
const { fileName, Description: description = '', Links: links, Design: designLink } = commission
const { date, creator } = parseCommissionFileName(fileName)
const linkId = `#${kebabName}-${date}`
const formattedDate = parseAndFormatDate(date, 'yyyy/MM/dd')
const interestKey = `${kebabName}-${date}`
const quotedDescription = `"${description}"`

const hasCreator = Boolean(creator)
const hasDescription = Boolean(description)
const hasBoth = hasCreator && hasDescription

const displayLinks = selectDisplayLinks({ links, designLink })
const hasDisplayLinks = hasDisplayableLinks({ links, designLink })
---

<div class="flex w-full flex-wrap items-center gap-y-2 font-mono text-xs text-gray-800 md:text-sm dark:text-gray-300">
  <div class="flex items-center">
    <span class="mr-6 select-none md:mr-16">
      <a href={linkId} class="text-gray-800 no-underline dark:text-gray-300!">
        <time>{formattedDate}</time>
      </a>
    </span>

    <div class="flex items-center">
      {
        hasCreator ? (
          <span>{creator}</span>
        ) : hasDescription ? (
          <span>{quotedDescription}</span>
        ) : (
          <span>-</span>
        )
      }

      {
        hasBoth ? (
          <>
            <span class="mx-2 select-none md:mx-4">|</span>
            <span>{quotedDescription}</span>
          </>
        ) : null
      }
    </div>
  </div>

  <div class="ml-auto flex grow justify-end">
    {
      showLinks ? (
        hasDisplayLinks ? (
          <>
            {
              displayLinks.mainLinks.map((link, index) => (
                <span class={index > 0 ? 'ml-2 md:ml-3' : ''}>
                  <a href={link.url} class={COMMISSION_LINK_TEXT_CLASS} target="_blank">
                    {link.type}
                  </a>
                </span>
              ))
            }
            {
              displayLinks.designLink ? (
                <span class={displayLinks.mainLinks.length > 0 ? 'ml-2 md:ml-3' : ''}>
                  <a href={displayLinks.designLink} class={COMMISSION_LINK_TEXT_CLASS} target="_blank">
                    {messages.listing.designLink}
                  </a>
                </span>
              ) : null
            }
          </>
        ) : (
          <button
            type="button"
            aria-pressed="false"
            data-link-style="true"
            class={`${COMMISSION_LINK_TEXT_CLASS} inline-flex cursor-pointer appearance-none items-center gap-2.5 border-0 bg-transparent p-0 disabled:cursor-default disabled:no-underline`}
            title={messages.listing.wantThisTitle}
            data-commission-interest-key={interestKey}
            data-commission-interest-recorded-label={messages.listing.wantThisRecorded}
            data-commission-interest-recorded-title={messages.listing.wantThisRecordedTitle}
          >
            <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-current opacity-80" />
            <span data-commission-interest-label>{messages.listing.wantThis}</span>
          </button>
        )
      ) : null
    }
  </div>
</div>
