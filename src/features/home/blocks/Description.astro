---
import type { Props as CommissionData } from '#data/types'
import type { HomeUpdateSummary } from '#lib/home/updateSummary'
import { getCharacterSectionHash, getCharacterTitleId } from '#lib/characters/nav'
import Update from '#features/home/blocks/Update.astro'

interface CommissionDescriptionProps {
  commissionData: CommissionData
  activeCharacters: string[]
  updateSummary?: HomeUpdateSummary
}

const { commissionData, activeCharacters, updateSummary } = Astro.props as CommissionDescriptionProps
const introductionTitle = 'Introduction'
const introductionTitleId = getCharacterTitleId(introductionTitle)
const introductionSectionHash = getCharacterSectionHash(introductionTitle)
---

<div id="--------Description--------">
  <h1 class="pb-0 md:pb-2">Commission Index</h1>
  <div id={introductionTitleId} class="mb-2 pt-4">
    <h2 class="group relative">
      {introductionTitle}
      <a
        href={introductionSectionHash}
        class="ml-2 font-bold text-gray-400 no-underline opacity-0 transition-opacity duration-200 group-hover:opacity-100 dark:text-gray-600"
      >
        #
      </a>
    </h2>
  </div>

  <p class="pt-4">
    Preview images are displayed alongside their corresponding links to platforms like Twitter,
    Pixiv, or Fantia when available. By clicking on these links, you can view the full image. You
    can also subscribe for updates through <a href="/rss.xml" target="_blank">RSS</a>.
  </p>
  <p class="pt-4 md:pt-6">
    I am not an illustrator but someone who frequently commissions artworks. If you appreciate the
    illustrations, please consider following and supporting the illustrators.
    <br />
    You may also consider to <a href="/support">support my commission projects</a>.
  </p>
  <p class="pt-4 md:pt-6">
    If any illustrators or readers wish to get in touch, don&apos;t hesitate to reach out through <a
      href="https://odaibako.net/u/CrystallizeSub">odaibako</a
    > or <a href="mailto:contact@crystallize.cc">Email</a>. Please note, any requests regarding
    the release or distribution of the illustrations will be ignored.
  </p>
  <Update commissionData={commissionData} activeCharacters={activeCharacters} summary={updateSummary} />
</div>
