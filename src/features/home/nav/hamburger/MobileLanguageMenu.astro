---
import type { HomeLocaleOption } from '#features/home/i18n/homeLocale'
import { STYLES } from '#features/home/nav/hamburger/constants'
import { IconLanguage } from '@tabler/icons-react'

interface MobileLanguageMenuProps {
  locale: string
  localeOptions: HomeLocaleOption[]
  localeSwitcherLabel: string
}

const { locale, localeOptions, localeSwitcherLabel } = Astro.props as MobileLanguageMenuProps
const backdropStyle = {
  WebkitBackdropFilter: STYLES.backdrop,
  backdropFilter: STYLES.backdrop,
}
---

<div
  data-mobile-language-menu-root="true"
  class="
    pointer-events-none fixed right-8 bottom-8 z-90 size-10 opacity-100
    transition-all duration-200
    md:hidden
  "
>
  <div
    data-mobile-language-menu-anchor="true"
    class="pointer-events-auto absolute right-0 bottom-[calc(100%+0.75rem)]"
  >
    <details data-mobile-language-menu="true" class="group relative">
      <summary
        style={backdropStyle}
        aria-label={localeSwitcherLabel}
        class={`
          ${STYLES.floatingButton}
          cursor-pointer list-none
          [&::-webkit-details-marker]:hidden
        `}
      >
        <span class="sr-only">{localeSwitcherLabel}</span>
        <IconLanguage className="size-6" stroke={1.7} aria-hidden="true" />
      </summary>

      <ul
        data-mobile-language-menu-panel="true"
        style={backdropStyle}
        class="
          pointer-events-none absolute right-4 bottom-full z-95 mb-3 w-48
          origin-bottom-right translate-y-1 scale-95 space-y-1 rounded-xl border
          border-white/20 bg-white/80 p-2 font-mono opacity-0
          shadow-[0_8px_30px_rgb(0,0,0,0.12)] transition-[opacity,transform]
          duration-220 ease-out
          dark:bg-black/80
        "
      >
        {
          localeOptions.map((option) => {
            const isActive = option.locale === locale
            return (
              <li>
                <a
                  href={option.href}
                  aria-current={isActive ? 'page' : undefined}
                  class={`group flex w-full items-center justify-between rounded-lg px-4 py-1 font-mono text-sm no-underline transition-colors duration-150 ${
                    isActive
                      ? 'text-gray-900 dark:text-white'
                      : 'text-gray-700 hover:bg-white/70 dark:text-gray-200 dark:hover:bg-white/10'
                  }`.trim()}
                >
                  <span>{option.label}</span>
                  {isActive
? (
                    <span
                      aria-hidden="true"
                      class="
                        size-1.5 rounded-full bg-gray-500/80
                        dark:bg-gray-300/80
                      "
                    />
                  )
: null}
                </a>
              </li>
            )
          })
        }
      </ul>
    </details>
  </div>
</div>
