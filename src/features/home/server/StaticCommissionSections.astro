---
import type { CharacterCommissions } from '#data/types'
import type { TimelineYearGroup } from '#lib/commissions/timeline'
import { getHomeLocaleMessages, normalizeHomeLocale } from '#features/home/i18n/homeLocale'
import Listing from '#features/home/commission/Listing.astro'
import TimelineView from '#features/home/commission/TimelineView.astro'

type CharacterDisplay = {
  DisplayName: string
}

interface StaticCommissionSectionsProps {
  locale?: string
  activeChars: CharacterDisplay[]
  staleChars: CharacterDisplay[]
  commissionMap: Map<string, CharacterCommissions>
  timelineGroups: TimelineYearGroup[]
  characterAliasesMap: Map<string, string[]>
  creatorAliasesMap: Map<string, string[]>
  keywordAliasesMap: Map<string, string[]>
}

const {
  locale,
  activeChars,
  staleChars,
  commissionMap,
  timelineGroups,
  characterAliasesMap,
  creatorAliasesMap,
  keywordAliasesMap,
} =
  Astro.props as StaticCommissionSectionsProps
const messages = getHomeLocaleMessages(normalizeHomeLocale(locale))
const staleCommissionCount = staleChars.reduce(
  (count, chara) => count + (commissionMap.get(chara.DisplayName)?.Commissions.length ?? 0),
  0,
)
---

<div id="--------Commissions--------">
  <div data-commission-view-panel="character" data-commission-view-active="true" data-stale-loaded="false">
    {
      activeChars.map(chara => (
        <Listing
          locale={locale}
          Character={chara.DisplayName}
          status="active"
          commissionMap={commissionMap}
          characterAliasesMap={characterAliasesMap}
          creatorAliasesMap={creatorAliasesMap}
          keywordAliasesMap={keywordAliasesMap}
        />
      ))
    }
    {
      staleChars.length > 0 ? (
        <>
          <div data-stale-sections-placeholder="true" class="pb-10 pt-4">
            <div class="mx-auto max-w-lg border-t border-stone-200/80 pt-6 text-center dark:border-white/10">
              <div class="inline-flex max-w-full items-center gap-2 text-[11px] text-stone-500 dark:text-stone-400">
                <span class="font-mono tracking-[0.24em] uppercase">{messages.controls.staleCharacters}</span>
                <span class="inline-flex min-w-6 items-center justify-center rounded-full border border-stone-200/80 px-2 py-0.5 font-mono text-[10px] text-stone-700 dark:border-white/10 dark:text-stone-200">
                  {staleChars.length}
                </span>
              </div>

              <p class="mt-4 text-base leading-7 font-semibold text-stone-700 dark:text-stone-200">
                {messages.controls.staleCharactersCollapsedTitle}
              </p>
              <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-stone-500 dark:text-stone-400">
                {messages.controls.staleCharactersCollapsedHint}
              </p>

              <button
                type="button"
                data-load-stale-characters="true"
                class="group mt-4 inline-flex cursor-pointer items-center gap-2 rounded-full border border-stone-300/80 bg-transparent px-4 py-2 font-mono text-sm text-stone-600 transition-colors hover:border-stone-500 hover:text-stone-900 dark:border-white/10 dark:text-stone-300 dark:hover:border-white/20 dark:hover:text-white"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-4 w-4 text-stone-400 transition-transform duration-200 group-hover:translate-y-0.5 group-hover:text-current dark:text-stone-500"
                  fill="none"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="m6 9 6 6 6-6"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>{messages.controls.loadStaleCharacters}</span>
              </button>

              <p class="mt-3 font-mono text-[11px] text-stone-400 dark:text-stone-500">
                {messages.controls.formatCollapsedStaleCommissionCount(staleCommissionCount)}
              </p>
            </div>
          </div>
          <div data-stale-sections-container="true" />
          <template data-stale-sections-template="true">
            <div data-stale-divider="true" class="pb-8">
              <hr />
            </div>
            {
              staleChars.map(chara => (
                <Listing
                  locale={locale}
                  Character={chara.DisplayName}
                  status="stale"
                  commissionMap={commissionMap}
                  characterAliasesMap={characterAliasesMap}
                  creatorAliasesMap={creatorAliasesMap}
                  keywordAliasesMap={keywordAliasesMap}
                />
              ))
            }
          </template>
        </>
      ) : null
    }
  </div>

  <div
    data-commission-view-panel="timeline"
    data-commission-view-active="false"
    data-timeline-loaded="false"
    class="hidden"
  >
    <div data-timeline-sections-container="true" />
    <template data-timeline-sections-template="true">
      <TimelineView
        groups={timelineGroups}
        characterAliasesMap={characterAliasesMap}
        creatorAliasesMap={creatorAliasesMap}
        keywordAliasesMap={keywordAliasesMap}
      />
    </template>
  </div>
</div>
