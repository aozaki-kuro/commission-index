---
import NotFoundPage from '#components/shared/NotFoundPage.astro'
import AdminSectionNav from '#admin/AdminSectionNav.astro'
import AdminSuggestionIsland from '#admin/islands/AdminSuggestionIsland'
import { getHomeSuggestionAdminData } from '#lib/admin/db'
import BaseLayout from '#layouts/BaseLayout.astro'

const initialPayload = getHomeSuggestionAdminData()
---

<BaseLayout title="Admin Suggestions" canonicalPath="/admin/suggestion">
  {
    import.meta.env.DEV ? (
      <div class="mx-auto max-w-5xl space-y-6 px-4 pt-6 pb-10 lg:px-0">
        <header class="space-y-2">
          <h1 class="text-2xl leading-tight font-semibold text-gray-900 dark:text-gray-100">
            Home Suggestions
          </h1>
          <p class="text-sm text-gray-600 dark:text-gray-300">
            Curate first-batch featured search keywords and keep order under manual control.
          </p>
        </header>

        <AdminSectionNav current="suggestion" />

        <AdminSuggestionIsland client:load initialPayload={initialPayload} />
      </div>
    ) : (
      <NotFoundPage />
    )
  }
</BaseLayout>
