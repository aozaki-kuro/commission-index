---
import NotFoundPage from '#components/shared/NotFoundPage.astro'
import AdminSectionNav from '#admin/AdminSectionNav.astro'
import AdminCreateIsland from '#admin/islands/AdminCreateIsland'
import { getAdminBootstrapData } from '#lib/admin/db'
import BaseLayout from '#layouts/BaseLayout.astro'

const initialPayload = getAdminBootstrapData()
---

<BaseLayout title="Admin Create" canonicalPath="/admin/create">
  {
    import.meta.env.DEV ? (
      <div class="mx-auto max-w-5xl space-y-6 px-4 pt-6 pb-10 lg:px-0">
        <header class="space-y-2">
          <h1 class="text-2xl leading-tight font-semibold text-gray-900 dark:text-gray-100">
            Create
          </h1>
          <p class="text-sm text-gray-600 dark:text-gray-300">
            Add characters and append commissions with validated source images.
          </p>
        </header>

        <AdminSectionNav current="create" />

        <AdminCreateIsland client:load initialPayload={initialPayload} />
      </div>
    ) : (
      <NotFoundPage />
    )
  }
</BaseLayout>
