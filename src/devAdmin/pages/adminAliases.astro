---
import NotFoundPage from '#components/shared/NotFoundPage.astro'
import AdminSectionNav from '#admin/AdminSectionNav.astro'
import AliasesDashboardIsland from '#admin/islands/AliasesDashboardIsland'
import { getCreatorAliasesAdminData } from '#lib/admin/db'
import BaseLayout from '#layouts/BaseLayout.astro'

const initialPayload = { creatorAliases: getCreatorAliasesAdminData() }
---

<BaseLayout title="Admin Aliases" canonicalPath="/admin/aliases">
  {
    import.meta.env.DEV ? (
      <div class="mx-auto max-w-5xl space-y-6 px-4 pt-6 pb-10 lg:px-0">
        <header class="space-y-2">
          <h1 class="text-2xl leading-tight font-semibold text-gray-900 dark:text-gray-100">
            Creator Aliases
          </h1>
          <p class="text-sm text-gray-600 dark:text-gray-300">
            Manage searchable romanized aliases for creators extracted from commission file names.
          </p>
        </header>

        <AdminSectionNav current="aliases" />

        <AliasesDashboardIsland client:load initialPayload={initialPayload} />
      </div>
    ) : (
      <NotFoundPage />
    )
  }
</BaseLayout>
