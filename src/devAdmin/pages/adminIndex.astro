---
import NotFoundPage from '#components/shared/NotFoundPage.astro'
import AdminSectionNav from '#admin/AdminSectionNav.astro'
import AdminDashboardIsland from '#admin/islands/AdminDashboardIsland'
import { getAdminBootstrapData } from '#lib/admin/db'
import BaseLayout from '#layouts/BaseLayout.astro'

const initialPayload = getAdminBootstrapData()
const tabStorageKey = 'admin-dashboard-tab-index'
const tabCount = 2

const readTabIndexFromCookie = (cookieHeader: string | null): number | undefined => {
  if (!cookieHeader) return undefined

  for (const chunk of cookieHeader.split(';')) {
    const [rawName, ...rest] = chunk.trim().split('=')
    if (rawName !== tabStorageKey) continue

    const rawValue = rest.join('=')
    try {
      const parsed = Number(decodeURIComponent(rawValue))
      if (Number.isFinite(parsed) && parsed >= 0 && parsed < tabCount) {
        return parsed
      }
    } catch {
      return undefined
    }

    return undefined
  }

  return undefined
}

const initialTabIndex = readTabIndexFromCookie(Astro.request.headers.get('cookie'))
---

<BaseLayout title="Admin" canonicalPath="/admin">
  {
    import.meta.env.DEV ? (
      <div class="mx-auto max-w-5xl space-y-6 px-4 pt-6 pb-10 lg:px-0">
        <header class="space-y-2">
          <h1 class="text-2xl leading-tight font-semibold text-gray-900 dark:text-gray-100">
            Commission Index Admin
          </h1>
          <p class="text-sm text-gray-600 dark:text-gray-300">
            Create new entries, reprioritize characters, and curate the commission archive.
          </p>
        </header>

        <AdminSectionNav current="admin" />

        <AdminDashboardIsland
          client:load
          initialPayload={initialPayload}
          initialTabIndex={initialTabIndex}
        />
      </div>
    ) : (
      <NotFoundPage />
    )
  }
</BaseLayout>
