---
import AdminPage from '#admin/AdminPage'
import NotFoundPage from '#components/shared/NotFoundPage'
import { getAdminData, getCreatorAliasesAdminData } from '#lib/admin/db'
import BaseLayout from '#layouts/BaseLayout.astro'

const isDev = import.meta.env.DEV
const initialPayload = isDev
  ? (() => {
      const { characters, commissions } = getAdminData()
      const creatorAliases = getCreatorAliasesAdminData()
      return { characters, commissions, creatorAliases }
    })()
  : null
---

<BaseLayout title="Admin" canonicalPath="/admin">
  {isDev ? <AdminPage client:load initialPayload={initialPayload} /> : <NotFoundPage />}
</BaseLayout>
