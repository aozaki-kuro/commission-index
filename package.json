{
  "name": "nsfw-commission-neo",
  "version": "1.3.0",
  "private": true,
  "author": "Crystallize",
  "type": "module",
  "scripts": {
    "assets:build": "bun run scripts/images.ts && bun run scripts/homeSearchEntries.ts && bun run scripts/rss.ts",
    "build": "bun run assets:build && next build",
    "build:offline": "NEXT_FONT_GOOGLE_MOCKED_RESPONSES=./scripts/nextFontGoogleMock.ts bun run build",
    "clean": "rm -rf .next node_modules out .wrangler && bun i",
    "deploy": "bun run build && wrangler deploy",
    "dev": "bun run assets:build && next dev --turbo",
    "images": "bun run scripts/images.ts",
    "images:convert": "bun run scripts/images.ts --convert-only",
    "images:prune-unused": "bun run scripts/images.ts --prune-unused",
    "lint": "eslint --fix",
    "pre-build": "bun run assets:build",
    "prepare": "prek install",
    "start": "next start",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx}": [
      "bun lint"
    ],
    "*.{json,css,md,mdx,jsonc}": [
      "bun prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.3.1",
    "fuse.js": "^7.1.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/eslint__eslintrc": "^3.3.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "@j178/prek": "^0.3.4",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
