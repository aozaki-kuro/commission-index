{
  "name": "nsfw-commission-neo",
  "version": "1.3.0",
  "private": true,
  "author": "Crystallize",
  "type": "module",
  "scripts": {
    "assets:build": "bun run scripts/assets.ts --mode build",
    "assets:dev": "bun run scripts/assets.ts --mode dev",
    "build": "bun run assets:build && astro build",
    "clean": "rm -rf dist node_modules .wrangler && bun i",
    "deploy": "bun run build && wrangler deploy",
    "dev": "bun run scripts/dev.ts",
    "dev:astro": "NODE_ENV=development bun run assets:dev && astro dev",
    "dev:api": "NODE_ENV=development bun server/admin-api.ts",
    "images": "bun run scripts/images.ts",
    "images:convert": "bun run scripts/images.ts --convert-only",
    "images:prune-unused": "bun run scripts/images.ts --prune-unused",
    "lint": "eslint --fix",
    "perf:check": "bun run scripts/perf/check.ts",
    "prepare": "prek install",
    "preview": "astro preview",
    "start": "astro preview",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx}": [
      "bun lint"
    ],
    "*.{json,css,md,mdx,jsonc}": [
      "bun prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fuse.js": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@astrojs/react": "^4.4.2",
    "@eslint/js": "^9.39.3",
    "@j178/prek": "^0.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.18.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
