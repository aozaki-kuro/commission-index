{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Shanghai",
  "dependencyDashboard": true,
  "rangeStrategy": "replace",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "platformAutomerge": true
  },
  "packageRules": [
    {
      "description": "Astro core stack",
      "matchPackageNames": ["astro", "@astrojs/react", "@astrojs/check"],
      "groupName": "astro stack"
    },
    {
      "description": "React runtime packages",
      "matchPackageNames": ["react", "react-dom", "cmdk"],
      "groupName": "react runtime"
    },
    {
      "description": "Type declarations",
      "matchPackageNames": ["@types/react", "@types/react-dom", "@types/node", "@types/better-sqlite3"],
      "groupName": "types"
    },
    {
      "description": "Tailwind and styling ecosystem",
      "matchPackageNames": [
        "tailwindcss",
        "@tailwindcss/postcss",
        "postcss",
        "tailwind-merge",
        "class-variance-authority",
        "clsx",
        "eslint-plugin-better-tailwindcss"
      ],
      "groupName": "tailwind and styling"
    },
    {
      "description": "Lint and hooks tooling",
      "matchPackageNames": ["eslint", "@antfu/eslint-config", "lint-staged", "@j178/prek"],
      "groupName": "lint and hooks"
    },
    {
      "description": "Testing stack",
      "matchPackageNames": [
        "vitest",
        "jsdom",
        "@testing-library/jest-dom",
        "@testing-library/react",
        "@playwright/test"
      ],
      "groupName": "test stack"
    },
    {
      "description": "TypeScript toolchain",
      "matchPackageNames": ["typescript", "vite-tsconfig-paths"],
      "groupName": "typescript toolchain"
    },
    {
      "description": "Radix UI components",
      "matchPackagePrefixes": ["@radix-ui/"],
      "groupName": "radix ui"
    },
    {
      "description": "DnD kit",
      "matchPackageNames": ["@dnd-kit/core", "@dnd-kit/sortable", "@dnd-kit/utilities"],
      "groupName": "dnd-kit"
    },
    {
      "description": "Infra and native modules",
      "matchPackageNames": ["wrangler", "better-sqlite3", "sharp"],
      "groupName": "infra and native modules"
    },
    {
      "description": "Runtime utilities",
      "matchPackageNames": ["fuse.js", "@tabler/icons-react"],
      "groupName": "runtime utilities"
    },
    {
      "description": "Automerge stable minor and patch updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "description": "Never automerge high-risk or native/runtime-critical dependencies",
      "matchPackageNames": [
        "astro",
        "@astrojs/react",
        "@astrojs/check",
        "react",
        "react-dom",
        "cmdk",
        "wrangler",
        "sharp",
        "better-sqlite3"
      ],
      "automerge": false
    }
  ]
}
